{
  "$schema": "appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "umbracoDbDSN": "",
    "umbracoDbDSN_ProviderName": "Microsoft.Data.SqlClient"
  },
  "Umbraco": {
    "CMS": {
      "Global": {
        "Id": "1e2c2f9b-351d-4b9e-802b-f82263b58c64",
        "SanitizeTinyMce": true
      },
      "Content": {
        "AllowEditInvariantFromNonDefault": true,
        "ContentVersionCleanupPolicy": {
          "EnableCleanup": true
        },
        "DisableDeleteWhenReferenced": true,
        "DisableUnpublishWhenReferenced": true
      },
      "Unattended": {
        "UpgradeUnattended": true
      },
      "Security": {
        "AllowConcurrentLogins": false
      },
      "ModelsBuilder": {
        "ModelsMode": "SourceCodeAuto",
        "ModelsNamespace": "UmbracoApplicationIntegration.Models",
        "AcceptUnsafeModelsDirectory": true,
        "ModelsDirectory": "~/../UmbracoApplicationIntegration.Models/Content/Generated",
        "IncludeVersionNumberInGeneratedModels": false
      },
      "Integrations": {
        "Search": {
          "Algolia": {
            "Settings": {
              "ApplicationId": "",
              "AdminApiKey": "",
              "SearchApiKey": "",
              "IndexName": "ITBooksIndex",
              "HitsPerPage": 100
            }
          }
        }
      }
    },
    "Integrations": {
      "Crm": {
        "Hubspot": {
          "Settings": {
            "ApiKey": "",
            "PortalId": "",
            "FormId": "",
            "Region": ""
          }
        }
      }
    },
    "AuthorizedServices": {
      "Services": {
        "hubspot": {
          "DisplayName": "HubSpot",
          "ApiHost": "https://api.hubapi.com",
          "IdentityHost": "https://app-eu1.hubspot.com",
          "TokenHost": "https://api.hubapi.com",
          "RequestIdentityPath": "/oauth/authorize",
          "AuthorizationUrlRequiresRedirectUrl": true,
          "RequestTokenPath": "/oauth/v1/token",
          "RequestTokenFormat": "FormUrlEncoded",
          "JsonSerializer": "SystemTextJson",
          "ClientId": "",
          "ClientSecret": "",
          "Scopes": "oauth forms crm.objects.contacts.read crm.objects.contacts.write",
          "SampleRequest": "/crm/v3/objects/contacts?limit=10&archived=false"
        }
      }
    }
  },
  "uSync": {
    "Settings": {
      "AddOnPing": false,
      "DefaultSet": "Default",
      "ExportAtStartup": "None",
      "ExportOnSave": "None",
      "ImportAtStartup": "None",
      "ImportOnFirstBoot": false,
      "FailOnMissingParent": true,
      "FailOnDuplicates": true,
      "UiEnabledGroups": "Settings",
      "Folders": [ "uSync/UmbracoApplicationIntegration.Website" ]
    },
    "Sets": {
      "Default": {
        "IsSelectable": false,
        "DisabledHandlers": [
          "PublishedContentHandler",
          "MediaFileHandler",
          "MemberHandler",
          "MemberGroupHandler",
          "UserHandler",
          "UserGroupHandler",
          "PublicAccessHandler",
          "PartialFileHandler",
          "PartialMacroFileHandler",
          "ScriptFileHandler",
          "StyleSheetHandler",
          "DomainHandler",
          "MediaHandler",
          "ContentHandler",
          "ContentTemplateHandler"
        ],
        "HandlerDefaults": {
          "FailOnMissingParent": true
        },
        "Handlers": {
          "DictionaryHandler": {
            "Group": "Settings",
            "CreateOnly": true
          }
        }
      }
    }
  }
}
